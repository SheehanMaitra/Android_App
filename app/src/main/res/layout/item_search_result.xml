<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_selectable_surface"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageView
        android:id="@+id/imageResultThumb"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:contentDescription="@string/thumbnail_content_description"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textResultName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/photos_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textResultAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/photos_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textResultTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/photos_muted"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>

