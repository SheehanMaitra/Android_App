<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/photos_selected" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/photos_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/photos_surface" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/photos_border" />
        </shape>
    </item>
</selector>

