<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
    Search screen. Left panel: search criteria + results list.
    Right panel: preview of the selected result photo.
-->
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="photos.controller.SearchController"
            prefWidth="1100" prefHeight="640">

    <!-- ── Top bar ── -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
            <padding><Insets top="12" right="12" bottom="8" left="12"/></padding>
            <Label text="Search" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox spacing="10" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                <Button text="Back to Albums" onAction="#onBack"/>
            </HBox>
        </HBox>
    </top>

    <!-- ── Centre: criteria left, preview right ── -->
    <center>
        <HBox spacing="14" BorderPane.alignment="CENTER">
            <padding><Insets top="8" right="12" bottom="12" left="12"/></padding>

            <!-- Left: criteria + results list -->
            <VBox spacing="10" prefWidth="520" HBox.hgrow="ALWAYS">

                <Label text="Search mode" style="-fx-font-weight: bold;"/>
                <ToggleGroup fx:id="searchModeGroup"/>
                <HBox spacing="18">
                    <RadioButton fx:id="dateModeRadio" text="Date Range"
                                 toggleGroup="$searchModeGroup" selected="true"/>
                    <RadioButton fx:id="tagModeRadio"  text="Tags"
                                 toggleGroup="$searchModeGroup"/>
                </HBox>

                <GridPane hgap="12" vgap="8">
                    <Label text="Start date"  GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="startDatePicker"
                                GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="End date"    GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <DatePicker fx:id="endDatePicker"
                                GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                    <Label text="Tag 1"       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="tag1TypeCombo" promptText="type" editable="true"
                              GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <TextField fx:id="tag1ValueField" promptText="value"
                               GridPane.rowIndex="1" GridPane.columnIndex="2"
                               GridPane.columnSpan="2"/>

                    <Label text="Tag 2 (opt.)" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="tag2TypeCombo" promptText="type" editable="true"
                              GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <TextField fx:id="tag2ValueField" promptText="value"
                               GridPane.rowIndex="2" GridPane.columnIndex="2"
                               GridPane.columnSpan="2"/>

                    <Label text="Operator"    GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <HBox spacing="12" GridPane.rowIndex="3" GridPane.columnIndex="1"
                          GridPane.columnSpan="3">
                        <RadioButton fx:id="andRadio" text="AND"/>
                        <RadioButton fx:id="orRadio"  text="OR"/>
                    </HBox>
                </GridPane>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Search" onAction="#onSearch"/>
                    <Button text="Create Album From Results" onAction="#onCreateAlbumFromResults"/>
                </HBox>

                <Label text="Results" style="-fx-font-weight: bold;"/>
                <ListView fx:id="resultsListView" VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- Right: selected photo preview -->
            <VBox spacing="10" prefWidth="480" HBox.hgrow="ALWAYS">
                <Label text="Selected Photo" style="-fx-font-weight: bold;"/>
                <ImageView fx:id="resultImageView"
                           fitWidth="440" fitHeight="320"
                           preserveRatio="true" smooth="true"/>
                <Label fx:id="resultCaptionLabel" text="Caption:" wrapText="true"/>
                <Label fx:id="resultDateLabel"    text="Date:"/>
                <Label fx:id="resultTagsLabel"    text="Tags:"  wrapText="true"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
