<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ButtonType?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>

<!--
    Dialog pane for adding a tag (type + value) to a photo.
    Loaded programmatically in AlbumController via FXMLLoader.
-->
<DialogPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="photos.controller.AddTagController"
            headerText="Add Tag"
            prefWidth="380">

    <content>
        <GridPane hgap="12" vgap="12">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <columnConstraints>
                <ColumnConstraints minWidth="80" halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Tag type:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="typeCombo" editable="true"
                      prefWidth="240"
                      GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Value:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="valueField" promptText="e.g. New Brunswick"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <!-- Shown only when the user types a brand-new tag type -->
            <CheckBox fx:id="multipleCheckBox"
                      text="Allow multiple values of this type per photo"
                      GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        </GridPane>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="OK"/>
        <ButtonType fx:constant="CANCEL"/>
    </buttonTypes>
</DialogPane>
