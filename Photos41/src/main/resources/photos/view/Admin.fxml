<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="photos.controller.AdminController"
      spacing="12" prefWidth="640" prefHeight="420">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="Admin" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="newUsernameField" promptText="new username" HBox.hgrow="ALWAYS"/>
        <Button text="Create User" onAction="#onCreateUser"/>
        <Button text="Delete Selected" onAction="#onDeleteSelected"/>
    </HBox>

    <ListView fx:id="usersListView" VBox.vgrow="ALWAYS"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Log Out" onAction="#onLogout"/>
    </HBox>
</VBox>

